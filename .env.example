# ─── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key — powers all AI agents (prioritization, decomposition, chat)
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Optional: Google OAuth ─────────────────────────────────────────────────────
# Enables Google Sign-In. Without these the app runs in single-user mode (no login page).
# Get credentials at https://console.cloud.google.com → APIs & Services → Credentials
AUTH_SECRET=your_random_secret_here
AUTH_GOOGLE_ID=your_google_client_id_here
AUTH_GOOGLE_SECRET=your_google_client_secret_here

# ─── Optional: Slack Integration ───────────────────────────────────────────────
# Enables "Send to Slack" feature from task detail view.
# Create a Slack app at https://api.slack.com/apps
# Required redirect URI: http://localhost:3001/api/integrations/slack/callback
SLACK_CLIENT_ID=your_slack_client_id_here
SLACK_CLIENT_SECRET=your_slack_client_secret_here

# ─── Optional: App URL ─────────────────────────────────────────────────────────
# Only needed if Google OAuth or Slack is configured
NEXTAUTH_URL=http://localhost:3000
