# ─── AI Providers ──────────────────────────────────────────────────────────────
# HOLYTASK supports 5 AI providers. Configure via Settings UI in the app,
# or set env vars here as an alternative (env takes effect as fallback
# when no provider is active in Settings).
#
# Only one provider is active at a time. Anthropic is recommended —
# it powers the multi-step tool-calling agents.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...
# GOOGLE_AI_API_KEY=AIza...

# ─── Slack Integration ─────────────────────────────────────────────────────────
# Required for "Send to Slack" feature.
# Create a Slack app at https://api.slack.com/apps
# Add redirect URI: http://localhost:3001/api/integrations/slack/callback

SLACK_CLIENT_ID=your_slack_client_id_here
SLACK_CLIENT_SECRET=your_slack_client_secret_here
