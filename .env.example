# ─── Slack Integration ─────────────────────────────────────────────────────────
# Required for "Send to Slack" feature. Create a Slack app at https://api.slack.com/apps
# Add redirect URI: http://localhost:3001/api/integrations/slack/callback
SLACK_CLIENT_ID=your_slack_client_id_here
SLACK_CLIENT_SECRET=your_slack_client_secret_here

# ─── AI API Key (optional) ─────────────────────────────────────────────────────
# Alternative to configuring the key through the Settings UI in the app.
# If set here, it is used as a fallback when no key is configured in Settings.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
