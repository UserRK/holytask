# ─── AI Providers ──────────────────────────────────────────────────────────────
# HOLYTASK supports 2 AI providers. Configure via Settings UI in the app,
# or set env vars here as an alternative (env takes effect as fallback
# when no provider is active in Settings).
#
# Both providers support all features: agents (A/B/C) and chat (D).

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─── Slack Integration ─────────────────────────────────────────────────────────
# Required for "Send to Slack" feature.
# Create a Slack app at https://api.slack.com/apps
# Add redirect URI: http://localhost:3000/api/integrations/slack/callback

SLACK_CLIENT_ID=your_slack_client_id_here
SLACK_CLIENT_SECRET=your_slack_client_secret_here
